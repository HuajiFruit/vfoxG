# Build output
build/bin/
*.syso

# Compiled binaries
*.exe

# Vfox core runtime (user provides their own)
core/

# Dependencies
node_modules/
frontend/dist/*
!frontend/dist/.gitkeep
frontend/package.json.md5

# Wails generated bindings. Keep them in the repo so standalone
# frontend type-check/build works on a fresh clone.
!frontend/wailsjs/
!frontend/wailsjs/**

# IDE
.idea/
.vscode/
.claude/
.gemini/

# OS
.DS_Store
Thumbs.db

# Screenshots
snapshot/

# Temp / Debug
*.debug.txt
scratch/
debug_test.go

# Release builds (large binaries)
release/

# Generated nfpm config
nfpm.yaml
